#!name=TG链接重定向·Turrit默认
#!desc=打开 t.me 链接直接跳转至 Turrit
#!author=自用（Surge适配）
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Telegram.png
#!homepage=https://funny-carp-11.deno.dev/tg.plugin

[MITM]
hostname = %APPEND% t.me, telegram.me

[Script]
TG链接重定向 = type=http-request,pattern=^https?:\/\/(t\.me|telegram\.me)\/.+,script-path=https://funny-carp-11.deno.dev/tg.js,requires-body=false,timeout=10,argument=tme_redirect=Turrit&open_mode=html